# === EZmeet — environment (example) ===
# Copy to `.env` and fill in the BOOTSTRAP secrets below. Most product config
# (Google SSO, workspace name, domain, SMTP, AI keys, recording…) is configured
# later in the browser via the first-run /setup wizard + admin panel — NOT here.
# Never commit the real `.env`.

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=eam_meet
POSTGRES_USER=eam_meet
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://eam_meet:change-me@eam-meet-db:5432/eam_meet

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=change-me

# ── NextAuth (generate: openssl rand -hex 32) ───────────────
NEXTAUTH_URL=https://meet.example.com
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
AUTH_TRUST_HOST=true

# ── Public URL (used for the /setup link + OAuth redirect URIs) ──
PUBLIC_URL=https://meet.example.com
APP_URL=http://eam-meet:3000

# ── LiveKit (LIVEKIT_API_SECRET must match livekit.yaml + egress.yaml) ──
LIVEKIT_API_KEY=EAM_MEET_KEY
LIVEKIT_API_SECRET=your-livekit-secret-hex
LIVEKIT_URL=wss://meet.example.com/livekit
LIVEKIT_WS_URL=ws://livekit:7880

# ── Scheduled jobs (reminders / digest / recording retention) ──
CRON_SECRET=replace-with-random

# ─────────────────────────────────────────────────────────────
# OPTIONAL — configure these in the /setup wizard or admin panel
# (stored in the database). Uncomment to use env values as a fallback.
# ─────────────────────────────────────────────────────────────
# Google OAuth — recommended to paste in /setup instead:
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# Deepgram (STT) / DeepSeek (LLM) — or set in admin → Settings:
# DEEPGRAM_API_KEY=your-deepgram-key
# DEEPSEEK_API_KEY=your-deepseek-key

# First boot prints a one-time SETUP token to the container logs:
#   docker compose logs eam-meet | grep -A2 SETUP
# Open https://<your-domain>/setup and paste it to begin.
