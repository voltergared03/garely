generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === NextAuth Models ===
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// === App Models ===
model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String?   @unique
  emailVerified      DateTime?
  image              String?
  role               String    @default("member") // admin | member
  status             String    @default("active") // active | pending | disabled — default keeps existing users active
  timezone           String    @default("Europe/Kyiv")
  createdAt          DateTime  @default(now())
  lastLogin          DateTime?
  preferences        Json?
  // Credentials auth (optional — null for SSO-only users)
  passwordHash       String? // scrypt: scrypt$N$r$p$salt$hash (base64url)
  mustChangePassword Boolean   @default(false)
  // 2FA (TOTP)
  totpSecret         String? // AES-256-GCM encrypted at rest
  totpEnabled        Boolean   @default(false)
  totpBackupCodes    Json? // array of HMAC-SHA256 hashed single-use codes
  // Personal calendar (ICS) subscription feed — secret token in the URL is the
  // auth; rotating it revokes existing subscriptions.
  calendarFeedToken  String?   @unique

  accounts              Account[]
  sessions              Session[]
  createdMeetings       Meeting[]            @relation("MeetingCreator")
  participations        MeetingParticipant[]
  assignedTasks         MeetingTask[]        @relation("TaskAssignee")
  transcriptSegments    TranscriptSegment[]
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]
  speakerTracks         SpeakerTrack[]
  createdQuizzes        Quiz[]               @relation("QuizCreator")
  quizAssignments       QuizAssignment[]     @relation("QuizAssignee")
  departmentMemberships DepartmentMember[]
  taskComments          TaskComment[]
  taskAttachments       TaskAttachment[]
  taskCollaborations    TaskCollaborator[]
  memberships           Membership[]
  taskAssignments       TaskAssignment[]
  baseMemberships       BaseMember[]
  googleCalendar        GoogleCalendarConnection?
}

// Web Push (PWA) subscription endpoints — one user can have many devices.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String // client public key (base64url)
  auth      String // client auth secret (base64url)
  ua        String? // user-agent, for display in settings
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())

  @@index([userId])
}

// Self-registration requests awaiting admin approval. The applicant sets their
// own password up front (hashed); approval just provisions an active User.
// Requests expire after AUTH_REQUEST_TTL_DAYS (default 3).
model RegistrationRequest {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String // scrypt — same format as User.passwordHash
  status       String       @default("pending") // pending | approved | denied | expired
  createdAt    DateTime     @default(now())
  expiresAt    DateTime
  decidedAt    DateTime?
  decidedById  String?
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([expiresAt])
}

model Meeting {
  id                     String       @id @default(cuid())
  title                  String
  description            String?
  createdById            String
  createdBy              User         @relation("MeetingCreator", fields: [createdById], references: [id])
  scheduledAt            DateTime?
  durationMin            Int          @default(60)
  status                 String       @default("scheduled") // scheduled | live | ended | cancelled
  recurrence             Json? // { type: daily|weekly|biweekly|monthly, seriesId } when recurring
  recurrenceMaterialized Boolean      @default(false) // true once this occurrence has spawned its successor
  livekitRoom            String?      @unique
  joinToken              String?      @unique
  createdAt              DateTime     @default(now())
  endedAt                DateTime?
  reminderSent           Boolean      @default(false)
  // Google Calendar two-way sync: the linked Google event (null = not synced).
  // externalId = Google event id; externalCalendarId = the "Garely" calendar it
  // lives in; externalEtag drives change-detection on inbound sync.
  externalId             String? // Google Calendar event id
  externalCalendarId     String?
  externalEtag           String?
  externalSyncedAt       DateTime?
  // Post-meeting AI report lifecycle (null = none yet)
  reportStatus           String? // generating | ready | failed
  reportError            String?      @db.Text
  // AI options
  transcriptionEnabled   Boolean      @default(true)
  aiReportEnabled        Boolean      @default(true)
  allowGuests            Boolean      @default(true)
  agenda                 Json?
  departmentId           String?
  orgId                  String
  org                    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  participants  MeetingParticipant[]
  transcripts   TranscriptSegment[]
  reports       MeetingReport[]
  tasks         MeetingTask[]
  emailLog      EmailLog[]
  notifications Notification[]
  notes         MeetingNote?
  recordings    Recording[]
  speakerTracks SpeakerTrack[]
  joinRequests  JoinRequest[]
  quiz          Quiz?
  department    Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([departmentId])
  @@index([orgId, status, scheduledAt])
  @@index([externalId])
}

model JoinRequest {
  id        String    @id @default(cuid())
  meetingId String
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  guestName String
  status    String    @default("pending") // pending | approved | denied
  createdAt DateTime  @default(now())
  decidedAt DateTime?

  @@index([meetingId, status])
}

model Recording {
  id          String    @id @default(cuid())
  meetingId   String
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  egressId    String?
  fileName    String
  filePath    String
  fileSize    BigInt?
  durationSec Int?
  status      String    @default("ready") // processing | ready | failed
  permanent   Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  // Recording strategy. "egress" = legacy single room-composite MP4. "screen-audio"
  // = the B2-lite pipeline: continuous mixed audio (room-composite audio-only) +
  // screen-share TrackEgress segment(s), muxed offline into the final MP4.
  sourceType  String?   // egress | screen-audio
  // For "screen-audio": { audioEgressId, audioFile, screenSegments: [{ egressId,
  // fileName, startSec, durationSec, status }] } — drives the offline ffmpeg compose.
  meta        Json?

  @@index([meetingId])
  @@index([expiresAt])
}

// Per-speaker audio captured by the LiveKit agent (one file per participant per
// meeting). Unlike Recording (room_composite video), these isolate each
// speaker's voice so we can detect their language and re-transcribe a single
// speaker without affecting the others.
model SpeakerTrack {
  id                  String   @id @default(cuid())
  meetingId           String
  meeting             Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  speakerId           String? // User.id for registered participants; null for guests
  speaker             User?    @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  participantIdentity String // LiveKit participant identity (userId or guest-xxxx)
  speakerName         String?
  fileName            String
  filePath            String
  fileSize            BigInt?
  durationSec         Float?
  detectedLanguage    String? // post-meeting Deepgram detect_language result (ru | uk | en …)
  detectConfidence    Float?
  createdAt           DateTime @default(now())

  @@index([meetingId])
  @@index([speakerId])
}

model MeetingParticipant {
  id         String    @id @default(cuid())
  meetingId  String
  meeting    Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName  String?
  guestEmail String?
  rsvpStatus String    @default("pending") // pending | accepted | declined | tentative
  joinedAt   DateTime?
  leftAt     DateTime?
  role       String    @default("participant") // host | participant

  @@unique([meetingId, userId])
}

model TranscriptSegment {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  speakerName String?
  speakerId   String?
  speaker     User?    @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  content     String
  language    String? // ru | uk | en
  startTime   Float
  endTime     Float
  confidence  Float?
  isFinal     Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([meetingId, startTime])
  @@index([speakerId])
}

model MeetingReport {
  id           String   @id @default(cuid())
  meetingId    String
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  summary      String?  @db.Text
  agenda       Json?
  decisions    Json?
  followUps    Json?
  topics       Json? // extended report: per-topic discussion/decisions/tasks/openQuestions with transcript citations
  rawPrompt    String?  @db.Text
  rawResponse  String?  @db.Text
  modelUsed    String?
  tokensInput  Int?
  tokensOutput Int?
  generatedAt  DateTime @default(now())

  tasks MeetingTask[]

  @@index([meetingId])
}

model MeetingTask {
  id            String             @id @default(cuid())
  meetingId     String?
  meeting       Meeting?           @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  reportId      String?
  report        MeetingReport?     @relation(fields: [reportId], references: [id])
  title         String
  description   String?
  assigneeId    String?
  assignee      User?              @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeName  String?
  priority      String             @default("medium") // high | medium | low
  status        String             @default("open") // open | in_progress | done
  dueDate       DateTime?
  createdAt     DateTime           @default(now())
  source        String             @default("ai") // ai | manual
  completedAt   DateTime?
  sortOrder     Int                @default(0)
  externalId    String?
  externalUrl   String?
  externalSync  String?
  lastSyncedAt  DateTime?
  departmentId  String?
  department    Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  orgId         String
  org           Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parentId      String?
  parent        MeetingTask?       @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks      MeetingTask[]      @relation("Subtasks")
  comments      TaskComment[]
  attachments   TaskAttachment[]
  collaborators TaskCollaborator[]
  assignees     TaskAssignment[]

  @@index([assigneeId])
  @@index([status])
  @@index([meetingId])
  @@index([departmentId])
  @@index([parentId])
  @@index([orgId, status])
  @@index([orgId, parentId])
}

model EmailLog {
  id           String       @id @default(cuid())
  meetingId    String?
  meeting      Meeting?     @relation(fields: [meetingId], references: [id])
  recipient    String
  template     String
  mailersendId String?
  status       String       @default("sent")
  sentAt       DateTime     @default(now())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // meeting_starting | task_assigned | report_ready | action_item | mention
  title     String
  body      String?
  link      String? // URL to navigate to on click
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  read      Boolean      @default(false)
  meetingId String?
  meeting   Meeting?     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([orgId, userId])
}

model MeetingNote {
  id        String   @id @default(cuid())
  meetingId String   @unique
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  content   String   @default("") @db.Text
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Post-meeting comprehension quiz: an admin/creator generates AI questions from
// the report, edits them, then assigns to participants who must complete a
// comprehension check. One quiz per meeting.
model Quiz {
  id          String       @id @default(cuid())
  meetingId   String       @unique
  meeting     Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User         @relation("QuizCreator", fields: [createdById], references: [id])
  status      String       @default("draft") // draft | assigned
  openBook    Boolean      @default(false) // may the taker view the report/transcript while taking it
  language    String? // uk | en — workspace language at generation time
  questions   Json // [{ id, prompt, type: single|multi|boolean, options:[{id,text}], correctOptionIds:[], cites:[] }]
  createdAt   DateTime     @default(now())
  assignedAt  DateTime?
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  assignments QuizAssignment[]
}

model QuizAssignment {
  id           String    @id @default(cuid())
  quizId       String
  quiz         Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation("QuizAssignee", fields: [userId], references: [id], onDelete: Cascade)
  assignedById String
  status       String    @default("pending") // pending | completed
  score        Int? // number of correct answers
  maxScore     Int? // total questions
  answers      Json? // { [questionId]: [selectedOptionIds] }
  dueAt        DateTime?
  assignedAt   DateTime  @default(now())
  completedAt  DateTime?

  @@unique([quizId, userId])
  @@index([userId, status])
}

// === Departments (org structure) ===
// Users are grouped into departments (many-to-many via DepartmentMember; a user
// can belong to several). A membership flagged isLead marks a department lead.
// Meetings and tasks belong to at most one department, which drives access
// gating in Garely and the per-department Teable base routing (option A).
model Department {
  id           String       @id @default(cuid())
  name         String
  color        String? // hex accent for UI chips
  teableBaseId String? // Teable base this department's tasks sync to
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  members  DepartmentMember[]
  meetings Meeting[]
  tasks    MeetingTask[]

  @@index([orgId])
}

model DepartmentMember {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  isLead       Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@unique([departmentId, userId])
  @@index([userId])
}

// === Task collaboration: comments, file attachments (stored in a Docker
// volume), and extra collaborators. Subtasks use the MeetingTask self-relation. ===
model TaskComment {
  id         String      @id @default(cuid())
  taskId     String
  task       MeetingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorName String? // snapshot, survives user deletion
  body       String      @db.Text
  createdAt  DateTime    @default(now())

  @@index([taskId, createdAt])
}

model TaskAttachment {
  id           String      @id @default(cuid())
  taskId       String
  task         MeetingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName     String
  filePath     String // relative path within the task-attachments volume
  mimeType     String?
  fileSize     BigInt?
  uploadedById String?
  uploadedBy   User?       @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())

  @@index([taskId])
}

model TaskCollaborator {
  id        String      @id @default(cuid())
  taskId    String
  task      MeetingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([taskId, userId])
  @@index([userId])
}

// Multiple assignees per task/subtask (the "виконавці" set). MeetingTask.assigneeId
// stays as the denormalized primary/lead (= first assignee) for backward-compat
// with the ~50 sites that read a single assignee (reports, AI, calendar, lists).
model TaskAssignment {
  id        String      @id @default(cuid())
  taskId    String
  task      MeetingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([taskId, userId])
  @@index([userId])
}

// === Multi-tenancy (Phase 1, 2026-06-03) ===
// Single-DB multi-tenancy. Tenant-owned AGGREGATE ROOTS carry orgId; child rows
// inherit their parent's org (see garely-architecture memory). Self-host = exactly
// one Organization ("org #1"); hosted = many orgs in one schema. orgId is NULLABLE
// in this first additive migration → backfilled to org #1 → then made required
// (roadmap §12). RBAC stays on User.role this phase; Membership.role is seeded but
// not yet enforced.
enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships          Membership[]
  meetings             Meeting[]
  tasks                MeetingTask[]
  departments          Department[]
  quizzes              Quiz[]
  notifications        Notification[]
  registrationRequests RegistrationRequest[]
  emailLogs            EmailLog[]
  bases                Base[]
  serverConnections    ServerConnection[]
  googleCalendarConns  GoogleCalendarConnection[]
}

// Per-user Google Calendar link for two-way sync. OAuth tokens are encrypted at
// rest (lib/twofactor encryptSecret, AES-256-GCM, AUTH_SECRET-derived) — same
// scheme as the RDP credential vault. All sync is scoped to ONE dedicated
// "Garely" calendar (calendarId) in the user's account, so personal events are
// never touched. `syncToken` drives incremental events.list; the channel* fields
// hold the active events.watch push subscription (renewed before expiry).
model GoogleCalendarConnection {
  id                 String       @id @default(cuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId              String
  org                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  googleEmail        String? // connected Google account (display only)
  accessTokenCipher  String?      @db.Text
  refreshTokenCipher String?      @db.Text
  tokenExpiry        DateTime?
  scope              String?
  calendarId         String? // the dedicated "Garely" calendar id
  syncToken          String?      @db.Text // incremental events.list cursor
  channelId          String? // events.watch channel uuid
  resourceId         String? // events.watch resource id (for channels.stop)
  channelToken       String? // our verification token echoed in the webhook
  channelExpiry      DateTime?
  status             String       @default("active") // active | error | revoked
  lastError          String?      @db.Text
  lastSyncedAt       DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([orgId])
  @@index([channelId])
}

model Membership {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      OrgRole      @default(MEMBER)
  createdAt DateTime     @default(now())

  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId])
}

// === Base engine (Phase 2, 2026-06-04) — roadmap §14 ===
// Generic Airtable/Teable-like data engine: Base → Table → Field → Row → View.
// `Base` is a tenant aggregate root (carries orgId); Table/Field/Row/View inherit
// org via Base (the children-inherit rule). Cell values live in `Row.data` — a
// JSONB bag keyed by fieldId. The record model is named `Row` (NOT `Record`) to
// avoid shadowing TS's built-in Record<K,V>. `Table` maps to "BaseTable" (the SQL
// reserved word). `createdById` is a soft user reference (no FK), like MeetingNote.
model Base {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  icon        String?
  color       String?
  visibility  String       @default("org") // org = all org members | restricted = creator + explicit members
  createdById String?
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tables  Table[]
  members BaseMember[]

  @@index([orgId])
}

// Per-base sharing (Phase 2). A row = explicit access for a user to a
// `restricted` base. `org`-visible bases ignore this (every org member sees them).
model BaseMember {
  id           String   @id @default(cuid())
  baseId       String
  base         Base     @relation(fields: [baseId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         String   @default("editor") // viewer | editor | admin
  hiddenFields Json     @default("[]") // fieldIds hidden from this member
  createdAt    DateTime @default(now())

  @@unique([baseId, userId])
  @@index([userId])
}

model Table {
  id             String   @id @default(cuid())
  baseId         String
  base           Base     @relation(fields: [baseId], references: [id], onDelete: Cascade)
  name           String
  icon           String?
  primaryFieldId String? // soft ref → Field.id rendered as the row title
  // Per-table owner (soft user ref, like Base.createdById). The owner manages
  // THIS table — rename / delete / structure / transfer — even when they're only
  // a base editor; base-admins still supersede. Read access stays base-level.
  createdById    String?
  position       Int      @default(0)
  system         Boolean  @default(false) // app-managed (e.g. the per-org Tasks table) → not user-deletable
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fields Field[]
  rows   Row[]
  views  View[]

  @@index([baseId])
  @@map("BaseTable")
}

model Field {
  id        String   @id @default(cuid())
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  name      String
  type      String // text | longText | number | singleSelect | multiSelect | date | person | checkbox
  options   Json? // select {choices:[{id,name,color}]} | number {precision} | date {includeTime} | person {multiple}
  position  Int      @default(0)
  width     Int? // grid column width in px (null = type default)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tableId])
}

model Row {
  id            String             @id @default(cuid())
  tableId       String
  table         Table              @relation(fields: [tableId], references: [id], onDelete: Cascade)
  data          Json               @default("{}") // { [fieldId]: value } — value shape per field type
  createdById   String?
  position      Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  dateReminders BaseDateReminder[]
  comments      RowComment[]
  attachments   RowAttachment[]
  collaborators RowCollaborator[]
  assignments   RowAssignment[]
  taskMeta      TaskRow?

  @@index([tableId])
  @@index([tableId, position])
}

// Per-row comments (base engine). Soft user reference (authorName is a snapshot
// that survives user deletion), like TaskComment but without a User FK.
model RowComment {
  id         String   @id @default(cuid())
  rowId      String
  row        Row      @relation(fields: [rowId], references: [id], onDelete: Cascade)
  userId     String?
  authorName String?
  body       String   @db.Text
  createdAt  DateTime @default(now())

  @@index([rowId, createdAt])
}

// Generalized collaboration layer for base-engine Rows (Phase 3 — tasks re-home).
// Mirror the Task{Attachment,Collaborator,Assignment} tables, keyed by rowId, so
// any Row (starting with the Tasks system table) reuses files/collaborators/
// assignees. Soft userId (no FK), like RowComment, to avoid User-model churn.
model RowAttachment {
  id           String   @id @default(cuid())
  rowId        String
  row          Row      @relation(fields: [rowId], references: [id], onDelete: Cascade)
  fileName     String
  filePath     String
  mimeType     String?
  fileSize     BigInt?
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([rowId])
}

model RowCollaborator {
  id        String   @id @default(cuid())
  rowId     String
  row       Row      @relation(fields: [rowId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([rowId, userId])
  @@index([userId])
}

model RowAssignment {
  id        String   @id @default(cuid())
  rowId     String
  row       Row      @relation(fields: [rowId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([rowId, userId])
  @@index([userId])
}

// 1:1 sidecar carrying a task Row's structural FKs to app entities that are NOT
// base tables (Meeting/Department/MeetingReport) + the subtask parent link.
// Plain indexed columns (no cross-entity FKs here — referential cleanup runs in
// app code at cutover, so deleting a Meeting/Dept never orphans the owning Row).
model TaskRow {
  rowId        String    @id
  row          Row       @relation(fields: [rowId], references: [id], onDelete: Cascade)
  meetingId    String?
  reportId     String?
  departmentId String?
  parentRowId  String?
  source       String    @default("manual") // ai | manual
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([meetingId])
  @@index([departmentId])
  @@index([parentRowId])
}

// Idempotency log for date-field reminders (one row per row×field×target-day
// that has been notified). Keeps the daily reminder cron from re-sending.
model BaseDateReminder {
  id        String   @id @default(cuid())
  rowId     String
  fieldId   String
  dueOn     DateTime // target reminder day (UTC) — idempotency key
  createdAt DateTime @default(now())
  row       Row      @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@unique([rowId, fieldId, dueOn])
  @@index([rowId])
}

model View {
  id        String   @id @default(cuid())
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  name      String
  type      String   @default("grid") // grid | kanban | calendar
  config    Json     @default("{}") // { visibleFieldIds, fieldOrder, filters[], sorts[], groupByFieldId, kanbanStackFieldId, calendarDateFieldId, rowHeight }
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tableId])
}

// === Servers / Remote Access pillar (§15, 2026-06-08) — native browser RDP ===
// `ServerConnection` is a tenant aggregate root (carries orgId; children inherit).
// Access mirrors the task/base pattern (lib/server-access.ts): a server is visible iff
// admin OR an explicit user grant OR membership of a granted department (ServerAccess).
// RDP credentials are encrypted AT REST in `secretCipher` via lib/twofactor `encryptSecret`
// (AES-256-GCM, AUTH_SECRET-derived, fail-closed — same scheme as user 2FA + base password
// cells); the plaintext is NEVER returned to the browser and is decrypted ONLY by the Rust
// gateway at connect time. File transfer is DECOUPLED from the RDP stream (SFTP relay, §15.6),
// audited via `ServerFileTransfer`. Live + historical sessions live in `ServerSession`.
// User/department/creator refs are soft (no FK), like `Base.createdById`.
model ServerConnection {
  id           String       @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  host         String
  port         Int          @default(3389)
  protocol     String       @default("rdp") // rdp only (v1)
  username     String
  secretCipher String? // AES-256-GCM ciphertext of the password; never read back to client
  domain       String?
  settings     Json         @default("{}") // color-depth / perf flags / resolution policy
  departmentId String? // optional owning-department tag (org grouping; access is via ServerAccess)
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  accesses  ServerAccess[]
  sessions  ServerSession[]
  transfers ServerFileTransfer[]

  @@index([orgId])
}

// Explicit access grant: a user XOR a department (XOR enforced in app code). No org-wide
// servers in v1 — access is always explicit. Mirrors the task-assignment / base-member grants.
model ServerAccess {
  id           String           @id @default(cuid())
  connectionId String
  connection   ServerConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  userId       String?
  departmentId String?
  grantedById  String?
  createdAt    DateTime         @default(now())

  @@unique([connectionId, userId])
  @@unique([connectionId, departmentId])
  @@index([connectionId])
  @@index([userId])
  @@index([departmentId])
}

// Audit + live-session registry. The Rust gateway writes start/end + byte counts.
model ServerSession {
  id           String           @id @default(cuid())
  connectionId String
  connection   ServerConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  userId       String
  orgId        String
  status       String           @default("active") // active | ended | error
  clientIp     String?
  bytesIn      BigInt?
  bytesOut     BigInt?
  gatewayId    String?
  error        String?
  startedAt    DateTime         @default(now())
  lastSeenAt   DateTime? // heartbeat from the live client; a session is shown "in use" only while this stays fresh
  endedAt      DateTime?

  @@index([orgId, startedAt])
  @@index([connectionId])
  @@index([userId])
}

// File-transfer audit for the decoupled SFTP relay (§15.6).
model ServerFileTransfer {
  id           String           @id @default(cuid())
  connectionId String
  connection   ServerConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sessionId    String?
  userId       String
  orgId        String
  direction    String // up | down
  filename     String
  sizeBytes    BigInt           @default(0)
  status       String           @default("pending") // pending | active | done | error
  error        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([orgId, createdAt])
  @@index([connectionId])
  @@index([sessionId])
}
