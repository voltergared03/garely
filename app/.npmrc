# next-auth (beta) declares `peerOptional nodemailer@^6`, but we run nodemailer
# 8 (the ^6 line has a high-severity SMTP-injection advisory). next-auth only
# uses nodemailer for its Email provider, which this app does not use (Credentials
# + Google only), so the peer is irrelevant here. legacy-peer-deps lets `npm ci`
# install from the lockfile without failing on that optional peer conflict.
legacy-peer-deps=true
